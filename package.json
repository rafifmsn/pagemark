{
  "name": "pagemark",
  "displayName": "Pagemark",
  "version": "1.0.0",
  "description": "Convert web page to markdown with one click",
  "author": "Rafif Muchsin <rafif@rafifmsn.com>",
  "scripts": {
    "dev": "plasmo dev",
    "dev:verbose": "plasmo dev --verbose",
    "dev:firefox": "plasmo dev --target=firefox-mv3",
    "build": "plasmo build",
    "build:source": "plasmo build --source-maps",
    "build:chrome": "plasmo build --target=chrome-mv3 --zip",
    "build:firefox": "plasmo build --target=firefox-mv3 --zip --source-maps",
    "package": "plasmo package",
    "build:all": "pnpm run build:chrome && pnpm run build:firefox"
  },
  "dependencies": {
    "defuddle": "^0.13.0",
    "defuddle-js": "^0.1.0",
    "markdown-to-jsx": "^9.7.15",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "overrides": {
    "@parcel/watcher": "^2.5.6",
    "svelte": "^4.2.19",
    "content-security-policy-parser": "^0.6.0",
    "msgpackr": "^1.10.1",
    "esbuild": "^0.25.0",
    "tsup": "^8.3.5"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.10",
    "prettier": "3.2.4",
    "tailwindcss": "3",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "contextMenus",
      "storage",
      "sidePanel"
    ],
    "commands": {
      "convert-to-markdown": {
        "suggested_key": {
          "default": "Ctrl+Shift+K",
          "mac": "Command+Shift+K"
        },
        "description": "Convert current page to Markdown"
      }
    },
    "browser_specific_settings": {
      "gecko": {
        "id": "rafifmsn@pagemark",
        "data_collection_permissions": {
          "required": [
            "none"
          ]
        }
      }
    }
  }
}